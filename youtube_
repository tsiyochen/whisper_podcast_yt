<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whisper Podcast YouTube 綜合外框 - 進化版</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&family=Noto+Serif+TC:wght@600;900&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --theme-color: #E08D79;
            /* 暮色橘 */
            --white: #ffffff;
            --off-white: #FAF7F6;
            --light-orange: #F8E3DE;
            --dark-text: #4A3E3B;
            --navy-deep: #2C3E50;
            --green-screen: #00FF00;
            /* 剪映去背用純綠 */
            --shadow: 0 12px 40px rgba(224, 141, 121, 0.15);
        }

        body {
            margin: 0;
            padding: 60px 0;
            background-color: #1a1a1a;
            font-family: 'Noto Sans TC', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 120px;
        }

        .style-label {
            color: var(--white);
            background: var(--theme-color);
            padding: 8px 25px;
            border-radius: 50px;
            font-weight: bold;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(224, 141, 121, 0.3);
        }

        .yt-container {
            width: 1280px;
            height: 720px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
            background-color: var(--off-white);
        }

        .square-logo {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 12px;
            flex-shrink: 0;
            object-fit: cover;
        }

        .video-box {
            background-image: url('影片示意.png') !important;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
        }

        .video-una {
            background-image: url('una 單人.png') !important;
        }

        .video-karen {
            background-image: url('karen 單人.png') !important;
        }

        /* --- 風格 01：雙人對談框 --- */
        .style-01 {
            padding: 40px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            background: radial-gradient(circle at center, #FFF9F8 0%, #F4EBE8 100%);
        }

        .style-01 .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .style-01 .video-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            flex: 1;
        }

        .style-01 .video-placeholder {
            border-radius: 24px;
            border: 4px solid var(--white);
            box-shadow: var(--shadow);
        }

        /* --- 風格 02A：懸浮膠囊版 --- */
        .style-02A .floating-capsule {
            position: absolute;
            bottom: 45px;
            left: 50%;
            transform: translateX(-50%);
            width: 920px;
            height: 110px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            border-radius: 60px;
            display: flex;
            align-items: center;
            padding: 0 15px 0 15px;
            box-shadow: var(--shadow);
        }

        .style-02A .capsule-content {
            padding-left: 25px;
        }

        /* --- 風格 03：有機手感框 --- */
        .style-03 {
            background-color: var(--light-orange);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .style-03 .video-mask {
            width: 1220px;
            height: 660px;
            border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
            border: 6px solid var(--white);
        }

        .style-03 .floating-logo {
            position: absolute;
            bottom: 50px;
            left: 60px;
            background: white;
            padding: 10px;
            border-radius: 15px;
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* --- 風格 04/04A：品牌色塊框 --- */
        .style-04 {
            background-color: var(--theme-color);
            padding: 30px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }

        .style-04 .inner-video-full {
            flex: 1;
            border-radius: 15px;
        }

        .style-04 .inner-video-dual {
            flex: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .style-04 .inner-video-dual div {
            border-radius: 15px;
            border: 3px solid rgba(255, 255, 255, 0.3);
        }

        .style-04 .footer-bar {
            height: 100px;
            display: flex;
            align-items: center;
            gap: 25px;
            padding: 0 10px;
            color: white;
        }

        .blossom {
            position: absolute;
            font-size: 50px;
            color: rgba(224, 141, 121, 0.15);
            pointer-events: none;
        }
    </style>
</head>

